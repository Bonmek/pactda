# Environment variables for PactDA cross-chain PoC

# Solana sponsor wallet private key (base58 encoded)
# WARNING: Keep this secure in production, use secret management
# Example for testnet: Generate a new key with `solana-keygen new -o sponsored_wallet.json`
# Then use solana-keygen pubkey sponsored_wallet.json to get the public key
# and cat sponsored_wallet.json to get the private key array which you'll need to base58 encode
# (or copy the base58 already encoded version from the log if available)
# VITE_SPONSOR_PRIVATE_KEY=YourBase58EncodedPrivateKey

# Set to Solana cluster - devnet or testnet
VITE_SOLANA_NETWORK=testnet

# Sui network configuration
VITE_SUI_NETWORK=testnet

VITE_SPONSOR_PRIVATE_KEY=0x5e70a7968b159f8c4d7acf47c34362ef968f60342d07f51ab9105b6bb594bfb6
